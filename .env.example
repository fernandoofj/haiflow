# haiflow server port
PORT=3333

# Deployment environment: development (default) or production.
# Falls back to NODE_ENV if HAIFLOW_ENV is unset. In production, haiflow fails
# closed at boot on an insecure exposure (see HAIFLOW_HOST below) and rejects a
# weak/placeholder API key. Development is permissive (no tunnel required).
# HAIFLOW_ENV=development

# Address the server binds to. Defaults to 127.0.0.1 (loopback) so the origin is
# only reachable through a front proxy/tunnel — an identity layer (e.g.
# Cloudflare Access) then cannot be bypassed by hitting the port directly.
# In production, binding to a public interface (0.0.0.0 / a LAN/public IP)
# refuses to start unless HAIFLOW_ALLOW_PUBLIC_BIND=true. See DEPLOYMENT.md.
# HAIFLOW_HOST=127.0.0.1

# Acknowledge a public bind in production (you firewall the port and run your
# own identity layer). Only consulted when HAIFLOW_ENV=production.
# HAIFLOW_ALLOW_PUBLIC_BIND=false

# Directory for session state, queues, and responses
# HAIFLOW_DATA_DIR=/tmp/haiflow

# Used by hook scripts to reach the server (defaults to PORT if unset)
# HAIFLOW_PORT=3333

# API key for bearer token authentication (required)
HAIFLOW_API_KEY=your-secret-key

# Force every session to use this cwd. When set, the cwd field in
# /session/start request bodies is ignored (and a warning is logged if it
# differs). Use this to lock all sessions to a single project root.
# HAIFLOW_CWD=/Users/me/Sites/myproject

# Whether the request body may set its own cwd. Default: true.
# Set to "false" to require HAIFLOW_CWD on the server and reject any
# request that tries to set its own cwd.
# HAIFLOW_ALLOW_REQUEST_CWD=true

# Whether to install and inject the haiflow-guardrails skill. Default: true.
# When enabled, haiflow:
#   1. installs ~/.claude/skills/haiflow-guardrails/SKILL.md on server boot
#   2. sends "/haiflow-guardrails" into each new tmux session once Claude's
#      TUI is interactive, then waits until Claude has acknowledged it
# The skill instructs Claude to refuse paths outside cwd, refuse to read
# secrets, and refuse network exfiltration. Set to "false" to disable both
# the install and the per-session injection.
# HAIFLOW_GUARDRAILS=true

# How long (ms) /session/start waits for the SessionStart hook to link a Claude
# session id before giving up. A session that never links can't have its
# responses captured (almost always means hooks aren't wired), so start fails
# loudly instead of reporting a healthy session. Default: 15000.
# HAIFLOW_START_READY_TIMEOUT_MS=15000

# --- Fire-and-forget completion callbacks (POST /trigger callbackUrl) ---
# Off by default: a caller-supplied callback URL is an SSRF surface. Set to
# "true" to let /trigger accept a callbackUrl that haiflow POSTs the result to
# when the task completes.
# HAIFLOW_ALLOW_TRIGGER_CALLBACK=false
# Optional comma-separated host allowlist for callbackUrl. With it set, a
# callback to any other host is rejected with 400.
# HAIFLOW_CALLBACK_ALLOW_HOSTS=my-app.example.com,hooks.internal

# Redis URL for pipeline pub/sub (optional — falls back to direct dispatch)
# REDIS_URL=redis://localhost:6379

# Optional. When set, GET /usage/window flags alert=true once the rolling
# 5-hour token total crosses this number. Alert-only: it never throttles or
# holds work, it just surfaces a warning so you can ease off before a
# subscription rate limit. Leave unset to disable.
# HAIFLOW_USAGE_ALERT_TOKENS=5000000

# Default age (hours) above which POST /sessions/prune (and `haiflow prune`)
# reaps an offline session's state directory. Default: 24.
# HAIFLOW_SESSION_TTL_HOURS=24

# --- Watchdog (catches sessions wedged on a permission prompt) ---

# Hard per-task timeout in seconds. 0 (default) disables it. When set, a task
# running longer than this is flagged by the watchdog (and recovered if
# HAIFLOW_WATCHDOG_RECOVER=true). Keep it generous so a slow-but-legit task
# is not killed.
# HAIFLOW_TASK_TIMEOUT_SEC=0

# How long (seconds) a session flagged "waiting" by Claude's Notification hook
# may stay blocked before the watchdog acts. Default: 120.
# HAIFLOW_WAITING_GRACE_SEC=120

# Whether the watchdog may auto-recover a wedged session (send Escape, mark the
# task timed_out, drain the queue). Default: false (alert-only — it just logs a
# watchdog_triggered warning). POST /interrupt is the manual recovery either way.
# HAIFLOW_WATCHDOG_RECOVER=false

# How often (ms) the watchdog scans for wedged sessions and reaps timed-out map
# runs. Default: 15000. Lower it mainly for tests; 15s is plenty in production.
# HAIFLOW_WATCHDOG_INTERVAL_MS=15000

# --- Worker pools & map-reduce ---

# Max number of items one POST /map call may fan out. Default: 200.
# HAIFLOW_MAP_MAX_ITEMS=200

# How long (seconds) a map run waits for stragglers before the reducer fires
# with whatever has returned (labelled partial). Default: 1800.
# HAIFLOW_MAP_TIMEOUT_SEC=1800

# Take-the-wheel: allow the dashboard terminal to switch to a WRITABLE attach so
# you can type directly into a session from the browser. A writable terminal
# bypasses the prompt structural checks and the guardrail skill, so it is gated
# by HAIFLOW_API_KEY (the operator's root credential). Set to "false" to disable
# the writable mode entirely (the read-only view always works). Default: true.
# HAIFLOW_ALLOW_TAKEOVER=true

# --- Secret redaction (best-effort DLP on outbound text) ---

# Strip well-known credential shapes (AWS/GitHub/Stripe/Google/Anthropic/OpenAI
# keys, JWTs, Bearer tokens, private-key blocks) out of responses, pipeline
# messages, webhooks and chat replies before they leave the box. Best-effort,
# not a firewall: it won't catch encoded/reshaped secrets and may false-positive.
# On by default; set to "false" to disable. Only outbound TEXT is touched, never
# files the agent writes inside its working directory.
# HAIFLOW_REDACT=true

# Also redact email addresses (noisier, so opt-in). Default: false.
# HAIFLOW_REDACT_EMAILS=false

# Extra redaction patterns as a JSON array of regex strings. Example:
# HAIFLOW_REDACT_EXTRA=["ACME-\\d{4,}","internal-[a-f0-9]{8}"]

# --- Signed inbound webhook gateway (POST /ingest/:source) ---

# Replay protection (one-use nonce per signed delivery) requires Redis. When
# Redis is unavailable the gateway fails CLOSED, rejecting signed requests with
# 503 so a captured webhook can't be replayed without limit. Set to "true" only
# if you knowingly run ingest without Redis and accept the replay risk. Default: false.
# HAIFLOW_INGEST_ALLOW_WITHOUT_REDIS=false

# How long (seconds) a signed delivery's replay nonce is remembered, separate
# from a recipe's freshness window. Schemes without a signed timestamp (github,
# untimestamped hmac) rely solely on this, so it bounds how often a captured
# webhook can be replayed. Default: 604800 (7 days).
# HAIFLOW_INGEST_NONCE_TTL_SEC=604800

# Per-source rate limit (requests/minute) for the public /ingest endpoint.
# Mitigates replay-flooding and resource abuse. Default: 120. Set 0 to disable.
# HAIFLOW_INGEST_RATE_PER_MIN=120

# n8n instance URL and API key for workflow integration
N8N_URL=http://localhost:5678
N8N_API_KEY=

# --- GitHub bridge (run with `haiflow github`) ---

# Override the haiflow base URL the bridge calls (default: http://localhost:$PORT)
# HAIFLOW_URL=http://localhost:3333

# Webhook secret configured on the GitHub App/repo webhook (required).
# GITHUB_WEBHOOK_SECRET=

# Comma-separated allowlists. BOTH are required for the bridge to act on
# anything — with either empty, every webhook is refused. This is the trust
# boundary: anyone who can comment on an allowlisted repo can drive Claude.
# GITHUB_ALLOWED_REPOS=acme/widgets,acme/api
# GITHUB_ALLOWED_SENDERS=alice,bob

# Which haiflow session the bridge drives (its cwd should be the cloned repo).
# GITHUB_SESSION=default

# Port the bridge listens on for GitHub webhooks. Default: 3334.
# GITHUB_PORT=3334

# Phrase that triggers the bridge in a comment. Default: "@haiflow".
# GITHUB_TRIGGER_PHRASE=@haiflow

# Whether to post Claude's summary back as a GitHub comment via gh. Default: true.
# GITHUB_POST_COMMENTS=true
