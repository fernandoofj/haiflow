{
  "name": "n8n-nodes-haiflow",
  "version": "0.1.0",
  "description": "n8n community node for haiflow, an HTTP orchestrator for Claude Code. Trigger prompts, stream responses, manage sessions, and receive pipeline webhooks.",
  "keywords": [
    "n8n-community-node-package",
    "haiflow",
    "claude",
    "claude-code",
    "orchestrator",
    "automation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/coderz/haiflow",
  "author": {
    "name": "Anderson Aguiar"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderz/haiflow.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "build:tsc": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"no lint configured\" && exit 0",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/HaiflowApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Haiflow/Haiflow.node.js",
      "dist/nodes/Haiflow/HaiflowTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "gulp": "^4.0.2",
    "n8n-workflow": "^2.16.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
